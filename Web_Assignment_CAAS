import json # Used for parsing JSON data.

def get_cat_image(query_type, user_input=None):
    """

    Args:
        query_type (str): The type of query (e.g., "random", "gif", "tag", "says").
        user_input (str, optional): User-provided input for tags or text.
    """

    base_url = "https://cataas.com/cat"

    if query_type == "random":
        url = base_url
    elif query_type == "gif":
        url = f"{base_url}/gif"
    elif query_type == "tag":
        url = f"{base_url}/{user_input}" # Uses the user's tag as a URL path segment.
    elif query_type == "says":
        url = f"{base_url}/says/{user_input}" #  Uses the user's text as a URL path segment.
    elif query_type == "tag_says":
        tag, text = user_input.split(",", 1) # Assumes comma-separated input for tag and text.
        url = f"{base_url}/{tag}/says/{text}" # Uses both tag and text in the URL path.
    else:
        print("Invalid query type.")
        return

    try:
        response = requests.get(url) # Sends an HTTP GET request.
        response.raise_for_status() # Raises an exception for HTTP errors (e.g., 404, 500).
        
        # Determine if the response is JSON or an image based on the Content-Type header.
        if "image" in response.headers.get("Content-Type", ""): 
            with open("cat_image.jpg", "wb") as f: # Saves the image to a file.
                f.write(response.content) # Writes raw byte content to the file.
            print("Cat image saved as cat_image.jpg")
        else:
            print("Received unexpected response format (not an image).")

    except requests.exceptions.RequestException as e: # Catches any request-related exceptions.
        print(f"Error fetching cat image: {e}")

def main():
    """
    Prompts the user to select a query type and fetches the corresponding cat image.
    """

    query_options = {
        "1": "random",
        "2": "gif",
        "3": "tag",
        "4": "says",
        "5": "tag_says"
    }

    while True:
        print("\nChoose a query type:")
        print("1. Random Cat Image")
        print("2. Random Cat GIF")
        print("3. Cat with Specific Tag (e.g., cute)")
        print("4. Cat Saying Something (e.g., hello)")
        print("5. Cat with Tag and Saying Something (e.g., cute, hello)")
        print("6. Exit")

        choice = input("Enter your choice: ") # Prompts the user for input.

        if choice == "6":
            print("Exiting...")
            break

        query_type = query_options.get(choice) # Retrieves the chosen query type.

        if query_type:
            user_input = None
            if query_type == "tag":
                user_input = input("Enter the tag: ")
            elif query_type == "says":
                user_input = input("Enter the text: ")
            elif query_type == "tag_says":
                user_input = input("Enter tag and text separated by a comma (e.g., cute,hello): ")

            get_cat_image(query_type, user_input)
        else:
            print("Invalid choice. Please try again.")

if __name__ == "__main__":
    main()

